# Docmost Configuration Template

# App Configuration
APP_URL=http://localhost:3000
# APP_SECRET should be a unique random string of at least 32 characters
APP_SECRET=place_a_secure_secret_here

# Database Configuration
POSTGRES_DB=docmost
POSTGRES_USER=docmost
POSTGRES_PASSWORD=your_secure_db_password
DATABASE_URL=postgresql://docmost:your_secure_db_password@db:5432/docmost

# Redis Configuration
REDIS_URL=redis://redis:6379
